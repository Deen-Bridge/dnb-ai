# Get your Gemini API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# Confidence & abstention policy (optional — defaults shown)
# CONFIDENCE_LOW_THRESHOLD=0.40      # below this the service abstains
# CONFIDENCE_HIGH_THRESHOLD=0.70     # above this it answers without a caveat
# SCHOLAR_QUEUE_THRESHOLD=0.40       # religious answers at or below go to review
# CONFIDENCE_HIGH_STAKES_PENALTY=0.15
# CONFIDENCE_NO_SIGNAL_PRIOR=0.55
# CONFIDENCE_UNVERIFIED_CEILING=0.65

# Scholar review (reviewer endpoints are disabled until the token is set)
# SCHOLAR_REVIEW_TOKEN=generate_a_long_random_value
# REVIEW_EXPORT_PATH=data/review/reviewed.jsonl
# REDIS_URL=redis://localhost:6379   # makes the review queue durable

# Tafsir layer (optional — sensible defaults, no key required)
# QURAN_API_BASE=https://api.quran.com/api/v4
# QURAN_API_TIMEOUT=15
# TAFSIR_MAX_AYAT=10
# TAFSIR_CHAT_EXCERPT_CHARS=2500
# TAFSIR_CHAT_TIMEOUT=20
